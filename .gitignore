# Secrets — never commit these
*.env
.env.*
!.env.example
secrets/
**/google-services.json
**/GoogleService-Info.plist

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Generated code (run: dart run build_runner build)
# Generated files are committed — build_runner output is required for
# the project to compile without running codegen first.
*.g.dart
*.freezed.dart

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
.mise.local.toml

# Agent scaffolding
.ralph/

# Claude Code — local permissions are per-user, don't commit
.claude/settings.local.json

# Signing keys
*.keystore
*.keystore.old

android/build/

sentry.properties
sentry-wizard

# catalog validation cache
.cache/
ios_distribution_private_key
ios_distribution_private_key.pub

# Patrol generated bundle
integration_test/test_bundle.dart
screenshots/
