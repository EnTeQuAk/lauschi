# Spotify integration (true/false). When false, all Spotify UI and
# playback is disabled. Requires SPOTIFY_CLIENT_ID when enabled.
ENABLE_SPOTIFY=false

# Spotify PKCE client ID (public, not a secret)
SPOTIFY_CLIENT_ID=

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Sentry environment tag
SENTRY_ENVIRONMENT=development
