# Developer environment — loaded by mise for scripts and tooling.
# NOT passed to Flutter builds (use .env.app for that).

# Spotify API credentials (for catalog validation scripts)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# OpenCode API key (for AI-curated catalog scripts)
OPENCODE_API_KEY=

# Brave Search API key (for web search in review scripts)
BRAVE_API_KEY=

# Sentry (duplicated here so scripts can use it too if needed)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
