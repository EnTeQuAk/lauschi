  "fixed_sql": [
    {
      "name": "groups",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"groups\" (\"id\" TEXT NOT NULL, \"title\" TEXT NOT NULL, \"cover_url\" TEXT NULL, \"sort_order\" INTEGER NOT NULL DEFAULT 0, \"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"content_type\" TEXT NOT NULL DEFAULT 'hoerspiel', \"provider\" TEXT NULL, \"external_show_id\" TEXT NULL, \"parent_tile_id\" TEXT NULL REFERENCES \"groups\" (id) ON DELETE CASCADE, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "cards",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"cards\" (\"id\" TEXT NOT NULL, \"title\" TEXT NOT NULL, \"custom_title\" TEXT NULL, \"cover_url\" TEXT NULL, \"custom_cover_path\" TEXT NULL, \"card_type\" TEXT NOT NULL, \"provider\" TEXT NOT NULL DEFAULT 'spotify', \"provider_uri\" TEXT NOT NULL, \"spotify_artist_ids\" TEXT NULL, \"group_id\" TEXT NULL REFERENCES \"groups\" (id), \"episode_number\" INTEGER NULL, \"is_heard\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_heard\" IN (0, 1)), \"sort_order\" INTEGER NOT NULL DEFAULT 0, \"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"total_tracks\" INTEGER NOT NULL DEFAULT 0, \"available_until\" INTEGER NULL, \"audio_url\" TEXT NULL, \"duration_ms\" INTEGER NOT NULL DEFAULT 0, \"last_track_uri\" TEXT NULL, \"last_track_number\" INTEGER NOT NULL DEFAULT 0, \"last_position_ms\" INTEGER NOT NULL DEFAULT 0, \"last_played_at\" INTEGER NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "nfc_tags",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"nfc_tags\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"tag_uid\" TEXT NOT NULL UNIQUE, \"target_type\" TEXT NOT NULL, \"target_id\" TEXT NOT NULL, \"label\" TEXT NULL, \"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)));"
        }
      ]
    },
    {
      "name": "show_subscriptions",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"show_subscriptions\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"provider\" TEXT NOT NULL, \"external_show_id\" TEXT NOT NULL, \"title\" TEXT NOT NULL, \"cover_url\" TEXT NULL, \"group_id\" TEXT NOT NULL REFERENCES \"groups\" (id) ON DELETE CASCADE, \"max_episodes\" INTEGER NULL, \"last_synced_at\" INTEGER NULL, \"remote_last_item_added\" INTEGER NULL, \"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)));"
        }
      ]
    }
