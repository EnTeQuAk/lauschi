# App build config — passed to Flutter via --dart-define-from-file.
# Only keys the app needs at runtime belong here.

# Spotify integration (true/false). Requires SPOTIFY_CLIENT_ID when enabled.
ENABLE_SPOTIFY=false

# Spotify PKCE client ID (public, not a secret)
SPOTIFY_CLIENT_ID=

# Apple Music integration (true/false). Requires APPLE_MUSIC_DEVELOPER_TOKEN
# on Android. On iOS, the token is auto-generated from the MusicKit entitlement.
ENABLE_APPLE_MUSIC=false

# Apple Music JWT developer token for Android.
# Generate with: mise run catalog-token
# Not needed on iOS or when ENABLE_APPLE_MUSIC=false.
APPLE_MUSIC_DEVELOPER_TOKEN=

# Sentry error tracking (true/false). For TestFlight/Firebase testers only,
# disabled in public store builds.
ENABLE_SENTRY=false

# Sentry DSN (required when ENABLE_SENTRY=true)
SENTRY_DSN=

# Sentry environment tag
SENTRY_ENVIRONMENT=development
