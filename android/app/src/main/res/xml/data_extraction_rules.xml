<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ backup rules. Exclude databases from cloud backup
     and device-to-device transfer. -->
<data-extraction-rules>
  <cloud-backup>
    <exclude domain="database" path="." />
  </cloud-backup>
  <device-transfer>
    <exclude domain="database" path="." />
  </device-transfer>
</data-extraction-rules>
